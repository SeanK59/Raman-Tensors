        "2"}], "\[IndentingNewLine]", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"es", "\[ConjugateTranspose]"}], ".", 
          RowBox[{"Transpose", "[", 
           RowBox[{"RotationMatrix", "[", 
            RowBox[{"\[Theta]", ",", "Ns"}], "]"}], "]"}], ".", 
          RowBox[{"(", "RamanOhEg2", ")"}], ".", 
          RowBox[{"RotationMatrix", "[", 
           RowBox[{"\[Theta]", ",", "Ns"}], "]"}], ".", "ei"}], ")"}], "^", 
        "2"}], "\[IndentingNewLine]", "+", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"es", "\[ConjugateTranspose]"}], ".", 
